# ============================================
# JURNAL Tracker — Email sozlamalari
# ============================================
#
# Gmail orqali email yuborish uchun App Password kerak.
#
# QANDAY OLISH (5 daqiqa):
#   1. https://myaccount.google.com/security
#      → "2-Step Verification" yoqing (agar yoqilmagan bo'lsa)
#   2. https://myaccount.google.com/apppasswords
#      → "Mail" tanlang, "Other" sifatida "JURNAL Tracker" yozing
#      → 16-belgili parol oling (xosh, masalan: "abcd efgh ijkl mnop")
#   3. Quyidagi qiymatlarni to'ldiring va bu faylni .env nomi bilan saqlang
#
# ============================================

GMAIL_USER=yuldoshevtem@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Hisobot yuboriladigan manzil (default: GMAIL_USER bilan bir xil)
REPORT_TO=yuldoshevtem@gmail.com

# Email yuborish vaqti (24-soat formatida, default 21 = soat 21:00)
SEND_HOUR=21

# Server porti (default 5555)
PORT=5555
